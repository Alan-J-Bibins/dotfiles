set recolor "true"
set default-bg rgba(0,0,0,0.0)
set recolor-lightcolor rgba(0,0,0,0.7)
set recolor-darkcolor rgba(255,255,255,1)
set adjust-open "width"
set guioptions "sv"
set first-page-column 1:2
set font "Product Sans 10"
set selection-clipboard clipboard
map <Down> navigate next
map <Up> navigate previous
